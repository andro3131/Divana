---
import { useTranslations, type Locale } from '../../i18n/ui';
import { ABOUT_IMAGES } from '../../lib/constants';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const images = ABOUT_IMAGES;

const rotations = [-3, 3, -4, 2, -2, 4, -3, 2];
---

<div id="about-modal" class="fixed inset-0 z-[100] hidden bg-dark-950/95 backdrop-blur-md overflow-y-auto">
  <div class="min-h-full flex items-start justify-center p-4 md:p-8 py-12" id="about-modal-backdrop">
    <div class="relative bg-dark-800 rounded-2xl max-w-6xl w-full overflow-hidden border border-dark-700/50 shadow-2xl" id="about-modal-content">

      <!-- Close button -->
      <button id="about-modal-close" class="sticky top-4 float-right mr-4 mt-4 z-10 bg-dark-950/70 backdrop-blur-sm rounded-full p-2 text-white/70 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="p-6 md:p-10 pt-2">
        <h2 class="text-3xl md:text-4xl font-heading font-semibold text-gold-gradient inline-block mb-8">
          {t('about.title')}
        </h2>

        <!-- Mobile layout: alternating image + text blocks -->
        <div class="md:hidden space-y-10">
          <!-- Block 1 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-left`} style={`--rotate: ${rotations[0]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[0].src} alt={images[0].alt} class="w-full h-full object-cover object-top" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p>{t('about.bio1')}</p>
              <p>{t('about.bio2')}</p>
            </div>
          </div>

          <!-- Block 2 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-right`} style={`--rotate: ${rotations[1]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[1].src} alt={images[1].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p class="text-gold italic">{t('about.bio3')}</p>
              <p>{t('about.bio4')}</p>
            </div>
          </div>

          <!-- Block 3 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-left`} style={`--rotate: ${rotations[2]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[2].src} alt={images[2].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p>{t('about.bio5')}</p>
              <p>{t('about.bio6')}</p>
            </div>
          </div>

          <!-- Block 4 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-right`} style={`--rotate: ${rotations[3]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[3].src} alt={images[3].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p>{t('about.bio7')}</p>
            </div>
          </div>

          <!-- Block 5 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-left`} style={`--rotate: ${rotations[4]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[4].src} alt={images[4].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p>{t('about.bio8')}</p>
              <p>{t('about.bio9')}</p>
            </div>
          </div>

          <!-- Block 6 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-right`} style={`--rotate: ${rotations[5]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[5].src} alt={images[5].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p>{t('about.bio10')}</p>
            </div>
          </div>

          <!-- Block 7 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-left`} style={`--rotate: ${rotations[6]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[6].src} alt={images[6].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
            <div class="text-dark-200 leading-relaxed text-base space-y-4 text-justify">
              <p class="text-gold italic">{t('about.bio11')}</p>
            </div>
          </div>

          <!-- Block 8 -->
          <div class="space-y-5">
            <div class={`about-photo about-photo-right`} style={`--rotate: ${rotations[7]}deg`} data-modal-slide>
              <div class="mx-auto w-3/4 max-w-[280px] aspect-[4/3] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                <img src={images[7].src} alt={images[7].alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
          </div>
        </div>

        <!-- Desktop layout: 3-column with images on sides -->
        <div class="hidden md:grid md:grid-cols-[200px_1fr_200px] lg:grid-cols-[240px_1fr_240px] gap-8 lg:gap-12 items-start">
          <!-- Left column: images 0, 2, 4, 6 -->
          <div class="space-y-16 pt-8">
            {[0, 2, 4, 6].map((i) => (
              <div class="about-photo about-photo-left" style={`--rotate: ${rotations[i]}deg`} data-modal-slide>
                <div class="aspect-[3/4] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                  <img src={images[i].src} alt={images[i].alt} class="w-full h-full object-cover" loading="lazy" />
                </div>
              </div>
            ))}
          </div>

          <!-- Center column: text -->
          <div class="space-y-6 text-dark-200 leading-relaxed text-lg text-justify">
            <p>{t('about.bio1')}</p>
            <p>{t('about.bio2')}</p>
            <p class="text-gold italic">{t('about.bio3')}</p>
            <p>{t('about.bio4')}</p>
            <p>{t('about.bio5')}</p>
            <p>{t('about.bio6')}</p>
            <p>{t('about.bio7')}</p>
            <p>{t('about.bio8')}</p>
            <p>{t('about.bio9')}</p>
            <p>{t('about.bio10')}</p>
            <p class="text-gold italic">{t('about.bio11')}</p>
          </div>

          <!-- Right column: images 1, 3, 5, 7 -->
          <div class="space-y-16 pt-32">
            {[1, 3, 5, 7].map((i) => (
              <div class="about-photo about-photo-right" style={`--rotate: ${rotations[i]}deg`} data-modal-slide>
                <div class="aspect-[3/4] rounded-lg overflow-hidden border-2 border-gold/20 shadow-lg shadow-gold/10 bg-dark-900">
                  <img src={images[i].src} alt={images[i].alt} class="w-full h-full object-cover" loading="lazy" />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('about-modal');
  const content = document.getElementById('about-modal-content');
  const closeBtn = document.getElementById('about-modal-close');
  const backdrop = document.getElementById('about-modal-backdrop');

  // IntersectionObserver for slide-in animations inside modal
  const modalSlideObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('slide-in');
        } else {
          entry.target.classList.remove('slide-in');
        }
      });
    },
    { threshold: 0.1, root: modal }
  );

  // Random glow effect cycling
  let modalGlowInterval;
  let currentModalGlow = null;

  function modalRandomGlow() {
    if (currentModalGlow) {
      currentModalGlow.classList.remove('about-photo-glow');
    }
    const photos = modal.querySelectorAll('.about-photo.slide-in');
    if (photos.length > 0) {
      let next;
      do {
        next = photos[Math.floor(Math.random() * photos.length)];
      } while (next === currentModalGlow && photos.length > 1);
      next.classList.add('about-photo-glow');
      currentModalGlow = next;
    }
  }

  window.openAboutModal = function() {
    modal.classList.remove('hidden');
    content.classList.add('modal-enter');
    document.body.classList.add('lightbox-open');
    modal.scrollTop = 0;

    // Start observing slides
    modal.querySelectorAll('[data-modal-slide]').forEach((el) => {
      modalSlideObserver.observe(el);
    });

    // Start glow after slides animate in
    setTimeout(() => {
      modalRandomGlow();
      modalGlowInterval = setInterval(modalRandomGlow, 3000);
    }, 1000);
  };

  function closeAboutModal() {
    modal.classList.add('hidden');
    content.classList.remove('modal-enter');
    document.body.classList.remove('lightbox-open');

    // Cleanup
    clearInterval(modalGlowInterval);
    if (currentModalGlow) {
      currentModalGlow.classList.remove('about-photo-glow');
      currentModalGlow = null;
    }
    modal.querySelectorAll('[data-modal-slide]').forEach((el) => {
      modalSlideObserver.unobserve(el);
      el.classList.remove('slide-in');
    });
  }

  closeBtn?.addEventListener('click', closeAboutModal);

  backdrop?.addEventListener('click', (e) => {
    if (e.target === backdrop) closeAboutModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeAboutModal();
    }
  });
</script>
